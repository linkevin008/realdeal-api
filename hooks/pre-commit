#!/usr/bin/env bash
set -euo pipefail

echo "==> Running tests..."
# Exclude entry point and infra-wiring packages (cmd, config, database) — no testable logic
go test ./internal/handlers/... ./internal/middleware/... -coverprofile=/tmp/realdeal-api-coverage.out

COVERAGE=$(go tool cover -func=/tmp/realdeal-api-coverage.out | grep '^total' | awk '{print $3}' | tr -d '%')
THRESHOLD=90

echo "==> Coverage: ${COVERAGE}% (threshold: ${THRESHOLD}%)"

if (( $(echo "$COVERAGE < $THRESHOLD" | bc -l) )); then
    echo "ERROR: coverage ${COVERAGE}% is below threshold ${THRESHOLD}%"
    exit 1
fi

echo "==> OK"
